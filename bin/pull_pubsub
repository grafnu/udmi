#!/bin/bash -e

UDMI_ROOT=$(dirname $0)/..

source $UDMI_ROOT/etc/shell_common.sh

[[ $# -le 2 ]] || usage project_spec

project_spec=${1:-}
shift || true

read schema project_id namespace <<< $(echo $project_spec | tr / ' ')
echo "schema:$schema project_id:$project_id namespace:$namespace" >&2

suffix=${namespace#*+}

if [[ -z $namespace ]]; then
    suffix=${project_id#*+}
    project_id=${project_id%+*}
fi

[[ $suffix != $namespace ]] || suffix=
namespace=${namespace%%+*}

[[ -n $suffix ]] || suffix=$USER

echo "Using project $project_id namespace $namespace, suffix ${suffix}" >&2

[[ ! -n $namespace ]] || namespace=${namespace}~
subscription=${namespace}udmi_target+${suffix}
echo "Pulling from subscription $subscription" >&2

pull_limit=100

while true; do
    date -u -Is >&2
    pubsub_json=$(gcloud --format=json --project=$project_id pubsub subscriptions pull $subscription --limit $pull_limit --auto-ack 2>/dev/null || true)

    if [[ -z $pubsub_json || $pubsub_json == "[]" || $pubsub_json == null ]]; then
        sleep 1
        continue
    fi

    num_messages=$(echo "$pubsub_json" | jq '. | length' 2>/dev/null || echo 0)

    for index in $(seq 0 $((num_messages-1))); do
        message_json=$(echo "$pubsub_json" | jq -c ".[$index].message" 2>/dev/null || true)
        if [[ $message_json == null || -z $message_json ]]; then
            continue
        fi

        subType=$(echo "$message_json" | jq -r .attributes.subType 2> /dev/null || true)
        subFolder=$(echo "$message_json" | jq -r .attributes.subFolder 2> /dev/null || true)
        deviceId=$(echo "$message_json" | jq -r .attributes.deviceId 2> /dev/null || true)
        registryId=$(echo "$message_json" | jq -r .attributes.deviceRegistryId 2> /dev/null || true)
        timestamp=$(echo "$message_json" | jq -r .publishTime 2> /dev/null || true)
        raw_data=$(echo "$message_json" | jq -r .data 2>/dev/null || true)

        if [[ $raw_data == null || -z $raw_data ]]; then
            break
        fi

        # There's two different base64 formats, so replace _- with ++ to handle both.
        data=$(echo $raw_data | tr _- ++ | base64 --decode 2>/dev/null || true)

        if [[ -z $data ]]; then
            echo "Bad/empty message data: $raw_data" >&2
            continue
        fi

        if [[ $deviceId == "" ]]; then
            deviceId=empty
        fi

        if [[ $subType == null || $subType == "" ]]; then
            subType=events
        fi

        attributes_json=$(echo "$message_json" | jq -c .attributes 2>/dev/null || echo "{}")

        # Output single-line JSON to STDOUT
        jq -n \
          --arg devId "$deviceId" \
          --arg regId "$registryId" \
          --arg subF "$subFolder" \
          --arg subT "$subType" \
          --arg ts "$timestamp" \
          --arg projId "$project_id" \
          --arg rawPayload "$data" \
          '{
            envelope: {
              deviceId: $devId,
              deviceRegistryId: $regId,
              subFolder: $subF,
              subType: $subT,
              publishTime: $ts,
              projectId: $projId
            },
            payload: (try ($rawPayload | fromjson) catch $rawPayload)
          }' -c
    done
done
