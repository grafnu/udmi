#!/bin/bash -e

UDMI_ROOT=$(dirname $0)/..

source $UDMI_ROOT/etc/shell_common.sh

trap 'echo "pull_mqtt (PID $$) exited with status $? at $(date -u -Is)" >&2' EXIT
trap 'echo "pull_mqtt (PID $$) received SIGTERM at $(date -u -Is)" >&2' SIGTERM
trap 'echo "pull_mqtt (PID $$) received SIGPIPE at $(date -u -Is)" >&2' SIGPIPE
trap 'echo "pull_mqtt (PID $$) received SIGINT at $(date -u -Is)" >&2' SIGINT

[[ $# == 1 ]] || usage project_spec

project_spec=$1
shift

# Parse project_id from project_spec
spec_clean=${project_spec#//mqtt/}
spec_clean=${spec_clean%%%*}
projectId=$(echo "$spec_clean" | tr '/' ' ' | awk '{print $1}')
projectId=${projectId%+*}

registry_id=${project_spec##*%}
[[ $registry_id != $project_spec ]] || registry_id=+

source $UDMI_ROOT/etc/mosquitto_ctrl.sh

topic_filter_udmi="/r/${registry_id}/d/+/#"
topic_filter_uufi="/uufi/#"

echo "Starting mqtt message capture at $(date -u -Is) on topics $topic_filter_udmi and $topic_filter_uufi" >&2

mosquitto_sub $SERVER_OPTS -R -F "%j" -t $topic_filter_udmi -t $topic_filter_uufi |
    while read -r mqtt_message; do
        if [[ -z $mqtt_message ]]; then
            continue
        fi

        topic=$(jq -r .topic <<< "$mqtt_message" 2>/dev/null || true)
        payload=$(jq -r .payload <<< "$mqtt_message" 2>/dev/null || true)
        timestamp=$(jq -r .tst <<< "$mqtt_message" 2>/dev/null || true)

        if [[ -z $topic || $topic == null ]]; then
            continue
        fi

        readarray -d '/' -t array <<< "${topic}/"

        # Dynamically scan the array to identify key specifiers (r, d, c) in standard or UUFI formats
        r_idx=-1
        d_idx=-1
        c_idx=-1
        for i in "${!array[@]}"; do
            part=$(echo "${array[i]}" | xargs)
            if [[ $part == "r" ]]; then
                r_idx=$i
            elif [[ $part == "d" ]]; then
                d_idx=$i
            elif [[ $part == "c" ]]; then
                c_idx=$i
            fi
        done

        registryId=""
        deviceId=""
        subType=""
        subFolder=""

        if [[ $r_idx -ge 0 ]]; then
            registryId=${array[r_idx+1]:-}
        fi
        if [[ $d_idx -ge 0 ]]; then
            deviceId=${array[d_idx+1]:-}
        fi

        if [[ $c_idx -ge 0 ]]; then
            subType=${array[c_idx+1]:-}
            subFolder=${array[c_idx+2]:-}
        else
            if [[ $d_idx -ge 0 ]]; then
                subType=${array[d_idx+2]:-}
                subFolder=${array[d_idx+3]:-}
            elif [[ $r_idx -ge 0 ]]; then
                subType=${array[r_idx+2]:-}
                subFolder=${array[r_idx+3]:-}
            fi
        fi

        subFolder=$(echo $subFolder | xargs)  # Trim whitespace
        [[ -n $subFolder ]] || subFolder=update

        subType=$(echo $subType | xargs)
        [[ -n $subType ]] || subType=events
        [[ $subType != "null" ]] || subType=events


        if [[ $deviceId == "" ]]; then
            deviceId=empty
        fi

        # Construct single-line JSON with envelope and payload, output to STDOUT
        jq -n \
          --arg devId "$deviceId" \
          --arg regId "$registryId" \
          --arg subF "$subFolder" \
          --arg subT "$subType" \
          --arg ts "$timestamp" \
          --arg projId "$projectId" \
          --arg rawPayload "$payload" \
          '{
            envelope: {
              deviceId: $devId,
              deviceRegistryId: $regId,
              subFolder: $subF,
              subType: $subT,
              publishTime: $ts,
              projectId: $projId
            },
            payload: (try ($rawPayload | fromjson) catch $rawPayload)
          }' -c
    done

echo "Finished mqtt message capture at $(date -u -Is)" >&2
